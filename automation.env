
## App
BASE_URL=https://automationexercise.com/
LOGIN=ezequiel_qa@tester.com
PASSWORD=12345678

## API Base
API_BASE_URL=https://automationexercise.com/api

## Endpoints
# GET  | 200 | Response: All products list
API_PRODUCTS_LIST_URL=${API_BASE_URL}/productsList

# GET  | 200 | Response: All brands list
API_BRANDS_LIST_URL=${API_BASE_URL}/brandsList

# POST | 200 | Param: search_product (ex: top, tshirt, jean) | Response: Searched products list
# POST | 400 | (without search_product) | Response: Bad request, search_product parameter is missing in POST request.
API_SEARCH_PRODUCT_URL=${API_BASE_URL}/searchProduct

# POST | 200 | Params: email, password | Response: User exists!
# POST | 400 | (without email) | Response: Bad request, email or password parameter is missing in POST request.
# POST | 404 | (invalid credentials) | Response: User not found!
# DELETE | 405 | Response: This request method is not supported.
API_VERIFY_LOGIN_URL=${API_BASE_URL}/verifyLogin

# POST   | 201 | Params: name, email, password, title, birth_date, birth_month, birth_year, firstname, lastname, company, address1, address2, country, zipcode, state, city, mobile_number | Response: User created!
API_CREATE_ACCOUNT_URL=${API_BASE_URL}/createAccount

# DELETE | 200 | Params: email, password | Response: Account deleted!
API_DELETE_ACCOUNT_URL=${API_BASE_URL}/deleteAccount

# PUT    | 200 | Params: name, email, password, title, birth_date, birth_month, birth_year, firstname, lastname, company, address1, address2, country, zipcode, state, city, mobile_number | Response: User updated!
API_UPDATE_ACCOUNT_URL=${API_BASE_URL}/updateAccount

# GET    | 200 | Param: email | Response: User Detail
API_GET_USER_DETAIL_URL=${API_BASE_URL}/getUserDetailByEmail
